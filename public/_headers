# Cloudflare Pages headers
# https://developers.cloudflare.com/pages/configuration/headers/

# OG images generated by Next's opengraph-image.tsx are served at paths
# like "/opengraph-image/" and "/<route>/opengraph-image/" without a
# .png extension, so Cloudflare serves them as application/octet-stream.
# Force the correct MIME type and a long cache.

/opengraph-image/
  Content-Type: image/png
  Cache-Control: public, max-age=86400, s-maxage=604800, immutable

/opengraph-image/index.txt
  Content-Type: image/png

/*/opengraph-image/
  Content-Type: image/png
  Cache-Control: public, max-age=86400, s-maxage=604800, immutable

/*/opengraph-image/index.txt
  Content-Type: image/png

# Long-cache static assets in /images/
/images/*
  Cache-Control: public, max-age=2592000, immutable

# Long-cache fingerprinted Next.js assets
/_next/static/*
  Cache-Control: public, max-age=31536000, immutable
